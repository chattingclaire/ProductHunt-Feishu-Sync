# Copy this file to .env and fill in your actual values
# cp .env.example .env

PH_BEARER_TOKEN=your_producthunt_bearer_token   # optional fallback
PH_WEEKLY_URL=https://www.producthunt.com/leaderboard/weekly/2025/44
PH_COOKIES=key1=value1; key2=value2              # optional, helps bypass 403

FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_TABLE_APP_ID=your_bitable_app_token
FEISHU_TABLE_ID=your_table_id
FEISHU_RECEIVER_OPEN_ID=your_open_id

TIMEZONE=Asia/Shanghai
